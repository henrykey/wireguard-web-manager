# WireGuard Manager Configuration

# Authentication Settings (set to "yes" to enable authentication)
ENABLE_AUTH=no

# Admin username
ADMIN_USERNAME=admin

# Admin password (use a strong password!)
ADMIN_PASSWORD=password123

# Session secret key (generate a new one for production)
SECRET_KEY=your-secret-key-here

# WireGuard Configuration Paths
WG_CONF_DIR=/etc/wireguard
CLIENT_OUTPUT_DIR=/app/clients
DB_PATH=/app/clients/clients.db